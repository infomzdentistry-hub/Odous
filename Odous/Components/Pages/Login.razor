@page "/login"
@using Odous.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-gradient-primary text-white rounded-top-4 py-4">
                    <div class="text-center">
                        <i class="bi bi-shield-lock-fill fs-1"></i>
                        <h2 class="mb-0 mt-2">Odous Dental Clinic</h2>
                        <p class="mb-0 opacity-75">Please login to continue</p>
                    </div>
                </div>
                <div class="card-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Username</label>
                        <input @bind="username" class="form-control form-control-lg" placeholder="Enter username" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Password</label>
                        <input @bind="password" type="password" class="form-control form-control-lg" placeholder="Enter password" />
                    </div>

                    <div class="d-grid gap-2">
                        <button class="btn btn-primary btn-lg" @onclick="HandleLogin">Login</button>
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger mt-3 text-center">
                            @errorMessage
                        </div>
                    }
                </div>
                <div class="card-footer bg-light rounded-bottom-4 text-center py-3">
                    <small class="text-muted">
                        Demo credentials: <strong>admin</strong> / <strong>admin123</strong>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-gradient-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }
</style>

@code {
    private string username = "";
    private string password = "";
    private string errorMessage = "";

    private void HandleLogin()
    {
        if (AuthService.Login(username, password))
        {
            Navigation.NavigateTo("/", true);
        }
        else
        {
            errorMessage = "Invalid username or password. Please try again.";
        }
    }
}