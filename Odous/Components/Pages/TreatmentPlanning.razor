@page "/treatmentplanning"
@using Odous.Models
@using Odous.Services
@inject PatientService PatientService
@inject TreatmentPlanService TreatmentPlanService
@inject IJSRuntime JS

<div class="container-fluid mt-4">
    <div class="card">
        <div class="card-header bg-success text-white">
            <h3>🦷 Treatment Planning</h3>
        </div>
        <div class="card-body">

            @* Patient Selection *@
            <div class="row mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Patient Name *</label>
                    <input class="form-control"
                           list="patientList"
                           @bind="patientName"
                           @bind:event="oninput"
                           placeholder="Type or select patient..." />
                    <datalist id="patientList">
                        @foreach (var p in patients)
                        {
                            <option value="@p.Name">@p.Name</option>
                        }
                    </datalist>
                </div>
                <div class="col-md-6">
                    @if (!string.IsNullOrEmpty(patientName))
                    {
                        <span class="badge bg-success mt-4">Selected: @patientName</span>
                    }
                    @if (!string.IsNullOrEmpty(saveMessage))
                    {
                        <span class="badge bg-info mt-4 ms-2">@saveMessage</span>
                    }
                    @if (!string.IsNullOrEmpty(procedureError))
                    {
                        <span class="badge bg-danger mt-4 ms-2">@procedureError</span>
                    }
                </div>
            </div>

            @* Dental Chart *@
            <div class="card mb-3">
                <div class="card-header bg-light fw-bold">Dental Chart - Click teeth to select</div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-6 text-center">
                            <h6>Upper Right</h6>
                            <div class="d-flex flex-wrap justify-content-center gap-2 mb-3">
                                @foreach (var tooth in upperRight)
                                {
                                    <button type="button"
                                            class="btn @(selectedTeeth.Contains(tooth) ? "btn-success" : "btn-outline-secondary")"
                                            style="width: 50px;"
                                            @onclick="() => ToggleTooth(tooth)">
                                        @tooth
                                    </button>
                                }
                            </div>
                        </div>
                        <div class="col-6 text-center">
                            <h6>Upper Left</h6>
                            <div class="d-flex flex-wrap justify-content-center gap-2 mb-3">
                                @foreach (var tooth in upperLeft)
                                {
                                    <button type="button"
                                            class="btn @(selectedTeeth.Contains(tooth) ? "btn-success" : "btn-outline-secondary")"
                                            style="width: 50px;"
                                            @onclick="() => ToggleTooth(tooth)">
                                        @tooth
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-6 text-center">
                            <h6>Lower Right</h6>
                            <div class="d-flex flex-wrap justify-content-center gap-2">
                                @foreach (var tooth in lowerRight)
                                {
                                    <button type="button"
                                            class="btn @(selectedTeeth.Contains(tooth) ? "btn-success" : "btn-outline-secondary")"
                                            style="width: 50px;"
                                            @onclick="() => ToggleTooth(tooth)">
                                        @tooth
                                    </button>
                                }
                            </div>
                        </div>
                        <div class="col-6 text-center">
                            <h6>Lower Left</h6>
                            <div class="d-flex flex-wrap justify-content-center gap-2">
                                @foreach (var tooth in lowerLeft)
                                {
                                    <button type="button"
                                            class="btn @(selectedTeeth.Contains(tooth) ? "btn-success" : "btn-outline-secondary")"
                                            style="width: 50px;"
                                            @onclick="() => ToggleTooth(tooth)">
                                        @tooth
                                    </button>
                                }
                            </div>
                        </div>
                    </div>

                    @if (selectedTeeth.Count > 0)
                    {
                        <div class="mt-3 text-center">
                            <span class="fw-bold">Selected: @string.Join(", ", selectedTeeth.OrderBy(t => t))</span>
                            <button class="btn btn-sm btn-secondary ms-2" @onclick="ClearTeeth">Clear</button>
                        </div>
                    }
                </div>
            </div>

            @* Procedure Buttons *@
            <div class="row mb-3">
                <div class="col-md-3 mb-2">
                    <div class="card bg-danger text-white">
                        <div class="card-body">
                            <h6>Extraction</h6>
                            <select class="form-select form-select-sm mb-2" @bind="extractionPrice">
                                <option value="2500">2,500 PKR</option>
                                <option value="3500">3,500 PKR</option>
                                <option value="4500">4,500 PKR</option>
                            </select>
                            <button class="btn btn-sm btn-light w-100" @onclick='() => AddProcedureGrouped("Extraction", extractionPrice)'>Add Extraction</button>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-2">
                    <div class="card bg-primary text-white">
                        <div class="card-body">
                            <h6>Filling</h6>
                            <select class="form-select form-select-sm mb-2" @bind="fillingPrice">
                                <option value="2500">Composite - 2,500</option>
                                <option value="3500">Glass Ionomer - 3,500</option>
                                <option value="4500">Ceramic - 4,500</option>
                            </select>
                            <button class="btn btn-sm btn-light w-100" @onclick='() => AddProcedureGrouped("Filling", fillingPrice)'>Add Filling</button>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-2">
                    <div class="card bg-warning text-dark">
                        <div class="card-body">
                            <h6>RCT</h6>
                            <select class="form-select form-select-sm mb-2" @bind="rctPrice">
                                <option value="7500">7,500 PKR</option>
                                <option value="8500">8,500 PKR</option>
                                <option value="11500">11,500 PKR</option>
                            </select>
                            <button class="btn btn-sm btn-light w-100" @onclick='() => AddProcedureGrouped("RCT", rctPrice)'>Add RCT</button>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-2">
                    <div class="card bg-success text-white">
                        <div class="card-body">
                            <h6>Crown</h6>
                            <select class="form-select form-select-sm mb-2" @bind="crownPrice">
                                <option value="8000">PFM B - 8,000</option>
                                <option value="10000">PFM A - 10,000</option>
                                <option value="12000">PFM A1 - 12,000</option>
                                <option value="21000">Zirconium - 21,000</option>
                            </select>
                            <button class="btn btn-sm btn-light w-100" @onclick='() => AddProcedureGrouped("Crown", crownPrice)'>Add Crown</button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-3 mb-2">
                    <div class="card bg-info text-white">
                        <div class="card-body">
                            <h6>Implant</h6>
                            <select class="form-select form-select-sm mb-2" @bind="implantPrice">
                                <option value="75000">75,000 PKR</option>
                                <option value="85000">85,000 PKR</option>
                                <option value="95000">95,000 PKR</option>
                            </select>
                            <button class="btn btn-sm btn-light w-100" @onclick='() => AddProcedureGrouped("Implant", implantPrice)'>Add Implant</button>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-2">
                    <div class="card bg-secondary text-white">
                        <div class="card-body">
                            <h6>Other Procedures</h6>
                            <button class="btn btn-sm btn-light w-100 mb-1" @onclick='() => AddFixedProcedureGrouped("Scaling & Polishing", 6500)'>Scaling (6,500)</button>
                            <button class="btn btn-sm btn-light w-100 mb-1" @onclick='() => AddFixedProcedureGrouped("Veneer", 28000)'>Veneer (28,000)</button>
                            <button class="btn btn-sm btn-light w-100" @onclick='() => AddFixedProcedureGrouped("Denture", 35000)'>Denture (35,000)</button>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 mb-2">
                    <div class="card bg-dark text-white">
                        <div class="card-body">
                            <h6>Actions</h6>
                            <button class="btn btn-sm btn-warning me-2" @onclick="SavePlan">💾 Save Plan</button>
                            <button class="btn btn-sm btn-info me-2" @onclick="PrintPlan">🖨️ Print</button>
                            <button class="btn btn-sm btn-danger" @onclick="ClearPlan">🗑️ Clear All</button>
                        </div>
                    </div>
                </div>
            </div>

            @* Treatment Plan Table - Grouped Display *@
            @if (currentItems.Count > 0)
            {
                <div class="card" id="printArea">
                    <div class="card-header bg-primary text-white">
                        <h6 class="mb-0">Treatment Plan for @patientName</h6>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-bordered mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Teeth Numbers</th>
                                    <th>Procedure</th>
                                    <th>Qty</th>
                                    <th>Price/Unit</th>
                                    <th>Total Price</th>
                                    <th>Discount (PKR)</th>
                                    <th>Final Price</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < currentItems.Count; i++)
                                {
                                    var item = currentItems[i];
                                    var index = i;
                                    <tr>
                                        <td>@(i + 1)</td>
                                        <td><strong>@item.ToothNumbers</strong></td>
                                        <td>@item.Procedure @item.ProcedureVariant</td>
                                        <td>@item.NumberOfTeeth</td>
                                        <td>PKR @item.PricePerUnit.ToString("N0")</td>
                                        <td>PKR @item.BasePrice.ToString("N0")</td>
                                        <td>
                                            <input type="number"
                                                   class="form-control form-control-sm"
                                                   style="width: 100px"
                                                   @bind="item.DiscountAmount"
                                                   @bind:event="onchange"
                                                   step="100" />
                                        </td>
                                        <td class="fw-bold text-success">PKR @item.FinalPrice.ToString("N0")</td>
                                        <td>
                                            <button class="btn btn-sm btn-danger" @onclick="() => RemoveItem(index)">Remove</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-secondary">
                                <tr>
                                    <td colspan="5" class="text-end fw-bold">TOTAL:</td>
                                    <td class="fw-bold">PKR @currentItems.Sum(i => i.BasePrice).ToString("N0")</td>
                                    <td class="fw-bold text-danger">PKR @currentItems.Sum(i => i.DiscountAmount).ToString("N0")</td>
                                    <td class="fw-bold text-success">PKR @currentItems.Sum(i => i.FinalPrice).ToString("N0")</td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            }

            @* History *@
            @if (history.Count > 0 && !string.IsNullOrEmpty(patientName))
            {
                <div class="card mt-3">
                    <div class="card-header bg-light">
                        <h6 class="mb-0">Treatment History - @patientName</h6>
                    </div>
                    <div class="card-body">
                        @foreach (var plan in history.OrderByDescending(p => p.CreatedAt))
                        {
                            <div class="border rounded p-2 mb-2">
                                <div class="d-flex justify-content-between">
                                    <small class="text-muted">@plan.CreatedAt.ToString("dd MMM yyyy")</small>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeletePlan(plan.Id)">Delete</button>
                                </div>
                                <small>
                                    @foreach (var item in plan.Items.Take(3))
                                    {
                                        <span class="badge bg-secondary me-1">@item.Procedure</span>
                                    }
                                    @if (plan.Items.Count > 3)
                                    {
                                        <span>...</span>
                                    }
                                </small>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<Patient> patients = new();
    private string patientName = "";
    private List<int> selectedTeeth = new();
    private List<TreatmentPlanItem> currentItems = new();
    private List<TreatmentPlan> history = new();
    private string procedureError = "";
    private string saveMessage = "";

    private decimal extractionPrice = 2500;
    private decimal fillingPrice = 2500;
    private decimal rctPrice = 7500;
    private decimal crownPrice = 8000;
    private decimal implantPrice = 75000;

    private List<int> upperRight = new() { 18, 17, 16, 15, 14, 13, 12, 11 };
    private List<int> upperLeft = new() { 21, 22, 23, 24, 25, 26, 27, 28 };
    private List<int> lowerRight = new() { 48, 47, 46, 45, 44, 43, 42, 41 };
    private List<int> lowerLeft = new() { 31, 32, 33, 34, 35, 36, 37, 38 };

    protected override async Task OnInitializedAsync()
    {
        await LoadPatients();
        await LoadHistory();
    }

    private async Task LoadPatients()
    {
        patients = await PatientService.GetAllPatientsAsync();
    }

    private async Task LoadHistory()
    {
        if (!string.IsNullOrWhiteSpace(patientName))
        {
            history = await TreatmentPlanService.GetByPatientAsync(patientName);
        }
    }

    private void ToggleTooth(int tooth)
    {
        if (selectedTeeth.Contains(tooth))
            selectedTeeth.Remove(tooth);
        else
            selectedTeeth.Add(tooth);
        procedureError = "";
        StateHasChanged();
    }

    private void ClearTeeth()
    {
        selectedTeeth.Clear();
        StateHasChanged();
    }

    private void AddProcedureGrouped(string procedure, decimal pricePerUnit)
    {
        if (string.IsNullOrWhiteSpace(patientName))
        {
            procedureError = "Please select a patient first!";
            return;
        }

        if (selectedTeeth.Count == 0)
        {
            procedureError = "Please select at least one tooth!";
            return;
        }

        var toothNumbers = string.Join(", ", selectedTeeth.OrderBy(t => t));
        var quantity = selectedTeeth.Count;
        var totalPrice = pricePerUnit * quantity;

        var existingItem = currentItems.FirstOrDefault(i => i.Procedure == procedure && i.PricePerUnit == pricePerUnit);
        
        if (existingItem != null)
        {
            existingItem.ToothNumbers = existingItem.ToothNumbers + ", " + toothNumbers;
            existingItem.NumberOfTeeth += quantity;
            existingItem.BasePrice += totalPrice;
        }
        else
        {
            currentItems.Add(new TreatmentPlanItem
            {
                ToothNumbers = toothNumbers,
                Procedure = procedure,
                ProcedureVariant = procedure,
                PricePerUnit = pricePerUnit,
                NumberOfTeeth = quantity,
                BasePrice = totalPrice,
                DiscountAmount = 0
            });
        }

        selectedTeeth.Clear();
        procedureError = "";
        StateHasChanged();
    }

    private void AddFixedProcedureGrouped(string procedure, decimal price)
    {
        if (string.IsNullOrWhiteSpace(patientName))
        {
            procedureError = "Please select a patient first!";
            return;
        }

        var toothNumbers = selectedTeeth.Count > 0 ? string.Join(", ", selectedTeeth.OrderBy(t => t)) : "N/A";
        var quantity = selectedTeeth.Count > 0 ? selectedTeeth.Count : 1;
        var totalPrice = price * quantity;

        var existingItem = currentItems.FirstOrDefault(i => i.Procedure == procedure);
        
        if (existingItem != null && selectedTeeth.Count > 0)
        {
            existingItem.ToothNumbers = existingItem.ToothNumbers + ", " + toothNumbers;
            existingItem.NumberOfTeeth += quantity;
            existingItem.BasePrice += totalPrice;
        }
        else
        {
            currentItems.Add(new TreatmentPlanItem
            {
                ToothNumbers = toothNumbers,
                Procedure = procedure,
                ProcedureVariant = "",
                PricePerUnit = price,
                NumberOfTeeth = quantity,
                BasePrice = totalPrice,
                DiscountAmount = 0
            });
        }

        selectedTeeth.Clear();
        procedureError = "";
        StateHasChanged();
    }

    private void RemoveItem(int index)
    {
        if (index >= 0 && index < currentItems.Count)
        {
            currentItems.RemoveAt(index);
            StateHasChanged();
        }
    }

    private void ClearPlan()
    {
        currentItems.Clear();
        saveMessage = "";
        StateHasChanged();
    }

    private async Task SavePlan()
    {
        if (string.IsNullOrWhiteSpace(patientName))
        {
            procedureError = "Please select a patient first!";
            return;
        }

        if (currentItems.Count == 0)
        {
            procedureError = "No items to save!";
            return;
        }

        try
        {
            var plan = new TreatmentPlan
            {
                PatientName = patientName,
                CreatedAt = DateTime.UtcNow,
                Items = currentItems.Select(i => new TreatmentPlanItem
                {
                    ToothNumbers = i.ToothNumbers,
                    Procedure = i.Procedure,
                    ProcedureVariant = i.ProcedureVariant,
                    PricePerUnit = i.PricePerUnit,
                    NumberOfTeeth = i.NumberOfTeeth,
                    BasePrice = i.BasePrice,
                    DiscountAmount = i.DiscountAmount
                }).ToList()
            };

            await TreatmentPlanService.SavePlanAsync(plan);
            saveMessage = "✅ Plan saved successfully!";
            currentItems.Clear();
            await LoadHistory();
            StateHasChanged();
            
            await Task.Delay(3000);
            saveMessage = "";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            procedureError = $"Error: {ex.Message}";
        }
    }

    private async Task DeletePlan(int id)
    {
        await TreatmentPlanService.DeletePlanAsync(id);
        await LoadHistory();
        StateHasChanged();
    }

    private async Task PrintPlan()
    {
        await JS.InvokeVoidAsync("window.print");
    }
}