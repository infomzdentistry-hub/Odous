@code {
    private List<Patient> patients = new();
    private string patientName = "";
    private List<int> selectedTeeth = new();
    private List<TreatmentPlanItem> currentItems = new();
    private List<TreatmentPlan> history = new();
    private string procedureError = "";
    private string saveMessage = "";

    private decimal extractionPrice = 2500;
    private decimal fillingPrice = 2500;
    private decimal rctPrice = 7500;
    private decimal crownPrice = 8000;
    private decimal implantPrice = 75000;

    private List<int> upperRight = new() { 18, 17, 16, 15, 14, 13, 12, 11 };
    private List<int> upperLeft  = new() { 21, 22, 23, 24, 25, 26, 27, 28 };
    private List<int> lowerRight = new() { 48, 47, 46, 45, 44, 43, 42, 41 };
    private List<int> lowerLeft  = new() { 31, 32, 33, 34, 35, 36, 37, 38 };

    protected override async Task OnInitializedAsync()
    {
        patients = await PatientService.GetAllPatientsAsync();
    }

    private string GetSelectedTeethString()
        => selectedTeeth.Count == 0 ? "" : string.Join(", ", selectedTeeth.OrderBy(t => t));

    private async Task OnPatientSelected(ChangeEventArgs e)
    {
        patientName = e.Value?.ToString() ?? "";
        history = new();
        saveMessage = "";
        if (!string.IsNullOrWhiteSpace(patientName))
            history = await TreatmentPlanService.GetByPatientAsync(patientName);
    }

    private void ToggleTooth(int tooth)
    {
        if (selectedTeeth.Contains(tooth)) selectedTeeth.Remove(tooth);
        else selectedTeeth.Add(tooth);
        procedureError = "";
        StateHasChanged();
    }

    private void ClearTeeth() { selectedTeeth.Clear(); StateHasChanged(); }

    private void AddProcedureGrouped(string procedure, decimal pricePerUnit)
    {
        procedureError = "";
        if (string.IsNullOrWhiteSpace(patientName)) { procedureError = "Please select a patient first!"; return; }
        if (selectedTeeth.Count == 0) { procedureError = "Please select at least one tooth!"; return; }

        var toothNumbers = string.Join(", ", selectedTeeth.OrderBy(t => t));
        var quantity = selectedTeeth.Count;
        var totalPrice = pricePerUnit * quantity;

        var existing = currentItems.FirstOrDefault(i => i.Procedure == procedure && i.PricePerUnit == pricePerUnit);
        if (existing != null)
        {
            existing.ToothNumbers = existing.ToothNumbers + ", " + toothNumbers;
            existing.NumberOfTeeth += quantity;
            existing.BasePrice += totalPrice;
        }
        else
        {
            currentItems.Add(new TreatmentPlanItem
            {
                ToothNumbers     = toothNumbers,
                Procedure        = procedure,
                ProcedureVariant = procedure,
                PricePerUnit     = pricePerUnit,
                NumberOfTeeth    = quantity,
                BasePrice        = totalPrice,
                DiscountAmount   = 0
            });
        }

        selectedTeeth.Clear();
        StateHasChanged();
    }

    private void AddBridgeGrouped()
    {
        procedureError = "";
        if (string.IsNullOrWhiteSpace(patientName)) { procedureError = "Please select a patient first!"; return; }
        if (selectedTeeth.Count < 2) { procedureError = "Select at least 2 teeth for a bridge."; return; }

        var variant = crownPrice switch
        {
            8000  => "PFM B",
            10000 => "PFM A",
            12000 => "PFM A1",
            21000 => "Zirconium",
            _     => "PFM B"
        };

        var units = selectedTeeth.Count;
        currentItems.Add(new TreatmentPlanItem
        {
            ToothNumbers     = string.Join(", ", selectedTeeth.OrderBy(t => t)),
            Procedure        = "Bridge",
            ProcedureVariant = variant,
            PricePerUnit     = crownPrice,
            NumberOfTeeth    = units,
            BasePrice        = crownPrice * units,
            DiscountAmount   = 0
        });

        selectedTeeth.Clear();
        StateHasChanged();
    }

    private void AddFixedProcedureGrouped(string procedure, decimal price)
    {
        procedureError = "";
        if (string.IsNullOrWhiteSpace(patientName)) { procedureError = "Please select a patient first!"; return; }

        var toothNumbers = selectedTeeth.Count > 0 ? string.Join(", ", selectedTeeth.OrderBy(t => t)) : "N/A";
        var quantity     = selectedTeeth.Count > 0 ? selectedTeeth.Count : 1;

        var existing = currentItems.FirstOrDefault(i => i.Procedure == procedure);
        if (existing != null && selectedTeeth.Count > 0)
        {
            existing.ToothNumbers   = existing.ToothNumbers + ", " + toothNumbers;
            existing.NumberOfTeeth += quantity;
            existing.BasePrice     += price * quantity;
        }
        else
        {
            currentItems.Add(new TreatmentPlanItem
            {
                ToothNumbers     = toothNumbers,
                Procedure        = procedure,
                ProcedureVariant = "",
                PricePerUnit     = price,
                NumberOfTeeth    = quantity,
                BasePrice        = price * quantity,
                DiscountAmount   = 0
            });
        }

        selectedTeeth.Clear();
        StateHasChanged();
    }

    private void RemoveItem(int index)
    {
        if (index >= 0 && index < currentItems.Count)
        {
            currentItems.RemoveAt(index);
            StateHasChanged();
        }
    }

    private void UpdateDiscount(int index, string value)
    {
        if (decimal.TryParse(value, out decimal amount))
        {
            currentItems[index].DiscountAmount = Math.Max(0, amount);
            StateHasChanged();
        }
    }

    private void ClearPlan() { currentItems.Clear(); saveMessage = ""; StateHasChanged(); }

    private async Task SavePlan()
    {
        if (string.IsNullOrWhiteSpace(patientName)) { procedureError = "Please select a patient first!"; return; }
        if (currentItems.Count == 0) { procedureError = "No items to save!"; return; }

        try
        {
            var plan = new TreatmentPlan
            {
                PatientName = patientName,
                CreatedAt   = DateTime.UtcNow,
                Items       = currentItems.Select(i => new TreatmentPlanItem
                {
                    ToothNumbers     = i.ToothNumbers,
                    Procedure        = i.Procedure,
                    ProcedureVariant = i.ProcedureVariant,
                    PricePerUnit     = i.PricePerUnit,
                    NumberOfTeeth    = i.NumberOfTeeth,
                    BasePrice        = i.BasePrice,
                    DiscountAmount   = i.DiscountAmount
                }).ToList()
            };

            await TreatmentPlanService.SavePlanAsync(plan);
            saveMessage = "✅ Saved!";
            currentItems.Clear();
            history = await TreatmentPlanService.GetByPatientAsync(patientName);
            StateHasChanged();

            await Task.Delay(3000);
            saveMessage = "";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            procedureError = $"Error: {ex.Message}";
        }
    }

    private async Task DeletePlan(int id)
    {
        await TreatmentPlanService.DeletePlanAsync(id);
        history = await TreatmentPlanService.GetByPatientAsync(patientName);
        StateHasChanged();
    }

    private async Task PrintPlan() => await JS.InvokeVoidAsync("window.print");
}