@page "/treatmentplanning"
@using Odous.Models
@using Odous.Services
@inject PatientService PatientService
@inject TreatmentPlanService TreatmentPlanService
@inject IJSRuntime JS

<div class="tp-wrapper">

    @* TOP BAR *@
    <div class="tp-topbar">
        <div class="tp-topbar-left">
            <input class="tp-patient-input"
                   list="patientList"
                   value="@patientName"
                   placeholder="🔍 Search or select patient..."
                   @onchange="OnPatientSelected" />
            <datalist id="patientList">
                @foreach (var p in patients)
                {
                    <option value="@p.Name" />
                }
            </datalist>
            @if (!string.IsNullOrEmpty(patientName))
            {
                <span class="tp-patient-badge">@patientName</span>
            }
        </div>
        <div class="tp-topbar-right">
            @if (!string.IsNullOrEmpty(saveMessage))
            {
                <span class="tp-save-msg">@saveMessage</span>
            }
            @if (!string.IsNullOrEmpty(procedureError))
            {
                <span class="tp-error-msg">⚠️ @procedureError</span>
            }
        </div>
    </div>

    @* DENTAL CHART *@
    <div class="tp-chart-area">
        <div class="tp-chart-label-row">
            <span class="tp-chart-label">Upper Right</span>
            <span class="tp-chart-label">Upper Left</span>
        </div>
        <div class="tp-teeth-row">
            @foreach (var tooth in upperRight)
            {
                var cls = selectedTeeth.Contains(tooth) ? "tp-tooth tp-tooth-selected" : "tp-tooth";
                <div class="@cls" @onclick="() => ToggleTooth(tooth)">
                    <svg viewBox="0 0 40 70" class="tp-tooth-svg">
                        <ellipse cx="20" cy="18" rx="14" ry="16" fill="currentColor" opacity="0.9"/>
                        <path d="M8 28 Q6 55 12 65 Q16 70 20 68 Q24 70 28 65 Q34 55 32 28 Z" fill="currentColor" opacity="0.85"/>
                        <ellipse cx="20" cy="18" rx="10" ry="11" fill="white" opacity="0.25"/>
                    </svg>
                    <span class="tp-tooth-num">@tooth</span>
                </div>
            }
            <div class="tp-midline"></div>
            @foreach (var tooth in upperLeft)
            {
                var cls = selectedTeeth.Contains(tooth) ? "tp-tooth tp-tooth-selected" : "tp-tooth";
                <div class="@cls" @onclick="() => ToggleTooth(tooth)">
                    <svg viewBox="0 0 40 70" class="tp-tooth-svg">
                        <ellipse cx="20" cy="18" rx="14" ry="16" fill="currentColor" opacity="0.9"/>
                        <path d="M8 28 Q6 55 12 65 Q16 70 20 68 Q24 70 28 65 Q34 55 32 28 Z" fill="currentColor" opacity="0.85"/>
                        <ellipse cx="20" cy="18" rx="10" ry="11" fill="white" opacity="0.25"/>
                    </svg>
                    <span class="tp-tooth-num">@tooth</span>
                </div>
            }
        </div>

        <div class="tp-teeth-row tp-lower-row">
            @foreach (var tooth in lowerRight)
            {
                var cls = selectedTeeth.Contains(tooth) ? "tp-tooth tp-tooth-selected" : "tp-tooth";
                <div class="@cls" @onclick="() => ToggleTooth(tooth)">
                    <span class="tp-tooth-num">@tooth</span>
                    <svg viewBox="0 0 40 70" class="tp-tooth-svg tp-tooth-svg-flipped">
                        <ellipse cx="20" cy="18" rx="14" ry="16" fill="currentColor" opacity="0.9"/>
                        <path d="M8 28 Q6 55 12 65 Q16 70 20 68 Q24 70 28 65 Q34 55 32 28 Z" fill="currentColor" opacity="0.85"/>
                        <ellipse cx="20" cy="18" rx="10" ry="11" fill="white" opacity="0.25"/>
                    </svg>
                </div>
            }
            <div class="tp-midline"></div>
            @foreach (var tooth in lowerLeft)
            {
                var cls = selectedTeeth.Contains(tooth) ? "tp-tooth tp-tooth-selected" : "tp-tooth";
                <div class="@cls" @onclick="() => ToggleTooth(tooth)">
                    <span class="tp-tooth-num">@tooth</span>
                    <svg viewBox="0 0 40 70" class="tp-tooth-svg tp-tooth-svg-flipped">
                        <ellipse cx="20" cy="18" rx="14" ry="16" fill="currentColor" opacity="0.9"/>
                        <path d="M8 28 Q6 55 12 65 Q16 70 20 68 Q24 70 28 65 Q34 55 32 28 Z" fill="currentColor" opacity="0.85"/>
                        <ellipse cx="20" cy="18" rx="10" ry="11" fill="white" opacity="0.25"/>
                    </svg>
                </div>
            }
        </div>

        <div class="tp-chart-label-row">
            <span class="tp-chart-label">Lower Right</span>
            <span class="tp-chart-label">Lower Left</span>
        </div>

        @if (selectedTeeth.Count > 0)
        {
            <div class="tp-selected-bar">
                <span>Selected: <strong>@string.Join(", ", selectedTeeth.OrderBy(t => t))</strong></span>
                <button class="tp-clear-btn" @onclick="ClearTeeth">✕ Clear</button>
            </div>
        }
    </div>

    @* MAIN BODY *@
    <div class="tp-body">

        @* LEFT PANELS *@
        <div class="tp-panels">

            @* Row 1 *@
            <div class="tp-panel-row">
                <div class="tp-panel tp-panel-extraction">
                    <div class="tp-panel-title">EXTRACTION/S</div>
                    <div class="tp-panel-field">
                        <label>Teeth Involved</label>
                        <input value="@GetSelectedTeethString()" readonly class="tp-input" />
                    </div>
                    <div class="tp-panel-field">
                        <label>No. of Teeth</label>
                        <input value="@selectedTeeth.Count" readonly class="tp-input" />
                    </div>
                    <div class="tp-panel-field">
                        <label>Procedure Price</label>
                        <select @bind="extractionPrice" class="tp-select">
                            <option value="2500">2,500</option>
                            <option value="3500">3,500</option>
                            <option value="4500">4,500</option>
                        </select>
                    </div>
                    <button class="tp-add-btn" @onclick='() => AddProcedureGrouped("Extraction", extractionPrice)'>+ Add</button>
                </div>

                <div class="tp-panel tp-panel-filling">
                    <div class="tp-panel-title">FILLING/S</div>
                    <div class="tp-panel-field">
                        <label>Teeth Involved</label>
                        <input value="@GetSelectedTeethString()" readonly class="tp-input" />
                    </div>
                    <div class="tp-panel-field">
                        <label>No. of Teeth</label>
                        <input value="@selectedTeeth.Count" readonly class="tp-input" />
                    </div>
                    <div class="tp-panel-field">
                        <label>Procedure Price</label>
                        <select @bind="fillingPrice" class="tp-select">
                            <option value="2500">2,500 — Composite</option>
                            <option value="3500">3,500 — Glass Ionomer</option>
                            <option value="4500">4,500 — Ceramic</option>
                        </select>
                    </div>
                    <button class="tp-add-btn" @onclick='() => AddProcedureGrouped("Filling", fillingPrice)'>+ Add</button>
                </div>
            </div>

            @* Row 2 *@
            <div class="tp-panel-row">
                <div class="tp-panel tp-panel-rct">
                    <div class="tp-panel-title">RCT/S</div>
                    <div class="tp-panel-field">
                        <label>Teeth Involved</label>
                        <input value="@GetSelectedTeethString()" readonly class="tp-input" />
                    </div>
                    <div class="tp-panel-field">
                        <label>No. of Teeth</label>
                        <input value="@selectedTeeth.Count" readonly class="tp-input" />
                    </div>
                    <div class="tp-panel-field">
                        <label>Procedure Price</label>
                        <select @bind="rctPrice" class="tp-select">
                            <option value="7500">7,500</option>
                            <option value="8500">8,500 — Re-Endo</option>
                            <option value="11500">11,500 — Re-Endo Complex</option>
                        </select>
                    </div>
                    <button class="tp-add-btn" @onclick='() => AddProcedureGrouped("RCT", rctPrice)'>+ Add</button>
                </div>

                <div class="tp-panel tp-panel-crown">
                    <div class="tp-panel-title">CROWN/BRIDGE</div>
                    <div class="tp-panel-field">
                        <label>Teeth Involved</label>
                        <input value="@GetSelectedTeethString()" readonly class="tp-input" />
                    </div>
                    <div class="tp-panel-field">
                        <label>No. of Teeth</label>
                        <input value="@selectedTeeth.Count" readonly class="tp-input" />
                    </div>
                    <div class="tp-panel-field">
                        <label>Procedure Price</label>
                        <select @bind="crownPrice" class="tp-select">
                            <option value="8000">8,000 — PFM B</option>
                            <option value="10000">10,000 — PFM A</option>
                            <option value="12000">12,000 — PFM A1</option>
                            <option value="21000">21,000 — Zirconium</option>
                        </select>
                    </div>
                    <div class="tp-panel-crown-btns">
                        <button class="tp-add-btn" @onclick='() => AddProcedureGrouped("Crown", crownPrice)'>+ Crown</button>
                        <button class="tp-add-btn tp-add-btn-alt" @onclick="AddBridgeGrouped">+ Bridge</button>
                    </div>
                </div>
            </div>

            @* Row 3 *@
            <div class="tp-panel-row">
                <div class="tp-panel tp-panel-implant">
                    <div class="tp-panel-title">IMPLANT/S</div>
                    <div class="tp-panel-field">
                        <label>Teeth Involved</label>
                        <input value="@GetSelectedTeethString()" readonly class="tp-input" />
                    </div>
                    <div class="tp-panel-field">
                        <label>No. of Teeth</label>
                        <input value="@selectedTeeth.Count" readonly class="tp-input" />
                    </div>
                    <div class="tp-panel-field">
                        <label>Procedure Price</label>
                        <select @bind="implantPrice" class="tp-select">
                            <option value="75000">75,000</option>
                            <option value="85000">85,000</option>
                            <option value="95000">95,000</option>
                        </select>
                    </div>
                    <button class="tp-add-btn" @onclick='() => AddProcedureGrouped("Implant", implantPrice)'>+ Add</button>
                </div>

                <div class="tp-panel tp-panel-extra">
                    <button class="tp-extra-btn tp-extra-reendo"  @onclick='() => AddFixedProcedureGrouped("Re-Endo Treatment", 11500)'>Re-Endo</button>
                    <button class="tp-extra-btn tp-extra-braces"  @onclick='() => AddFixedProcedureGrouped("Fixed Braces", 85000)'>Fixed Braces</button>
                    <button class="tp-extra-btn tp-extra-scaling" @onclick='() => AddFixedProcedureGrouped("Scaling & Polishing", 6500)'>Scaling &amp; Polishing</button>
                    <button class="tp-extra-btn tp-extra-sinus"   @onclick='() => AddFixedProcedureGrouped("Sinus Lift", 45000)'>Sinus Lift</button>
                    <button class="tp-extra-btn tp-extra-bone"    @onclick='() => AddFixedProcedureGrouped("Bone Graft", 35000)'>Bone Graft</button>
                    <button class="tp-extra-btn tp-extra-veneer"  @onclick='() => AddFixedProcedureGrouped("Veneer", 28000)'>Veneer</button>
                    <button class="tp-extra-btn tp-extra-denture" @onclick='() => AddFixedProcedureGrouped("Denture", 35000)'>Denture</button>
                </div>
            </div>

            @* Action Buttons *@
            <div class="tp-action-row">
                <button class="tp-action-btn tp-btn-save"  @onclick="SavePlan">💾 Save</button>
                <button class="tp-action-btn tp-btn-print" @onclick="PrintPlan">🖨️ Print</button>
                <button class="tp-action-btn tp-btn-clear" @onclick="ClearPlan">🗑️ Clear</button>
            </div>
        </div>

        @* RIGHT TABLE *@
        <div class="tp-table-area">
            <div class="tp-table-wrapper" id="printArea">
                <table class="tp-table">
                    <thead>
                        <tr>
                            <th>Teeth Involved</th>
                            <th>Procedure</th>
                            <th>Price/Unit</th>
                            <th>Qty</th>
                            <th>Total Price</th>
                            <th>Discount (PKR)</th>
                            <th>Final Price</th>
                            <th class="no-print">✕</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < currentItems.Count; i++)
                        {
                            var item = currentItems[i];
                            var index = i;
                            <tr class="@(index % 2 == 0 ? "tp-row-even" : "tp-row-odd")">
                                <td><strong>@item.ToothNumbers</strong></td>
                                <td>@item.Procedure @(item.Procedure != item.ProcedureVariant ? item.ProcedureVariant : "")</td>
                                <td>@item.PricePerUnit.ToString("N0")</td>
                                <td>@item.NumberOfTeeth</td>
                                <td>@item.BasePrice.ToString("N0")</td>
                                <td>
                                    <input type="number" min="0"
                                           class="tp-discount-input no-print"
                                           value="@item.DiscountAmount"
                                           @onchange="e => UpdateDiscount(index, e.Value?.ToString() ?? string.Empty)"
                                           step="100" />
                                    <span class="print-only">@item.DiscountAmount.ToString("N0")</span>
                                </td>
                                <td class="tp-final-price">@item.FinalPrice.ToString("N0")</td>
                                <td class="no-print">
                                    <button class="tp-del-btn" @onclick="() => RemoveItem(index)">✕</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                    @if (currentItems.Count > 0)
                    {
                        <tfoot>
                            <tr class="tp-totals-row">
                                <td colspan="4" class="text-end fw-bold">TOTAL</td>
                                <td class="fw-bold">@currentItems.Sum(i => i.BasePrice).ToString("N0")</td>
                                <td class="fw-bold text-danger">@currentItems.Sum(i => i.DiscountAmount).ToString("N0")</td>
                                <td class="fw-bold tp-final-price">@currentItems.Sum(i => i.FinalPrice).ToString("N0")</td>
                                <td class="no-print"></td>
                            </tr>
                        </tfoot>
                    }
                </table>
                @if (currentItems.Count == 0)
                {
                    <div class="tp-empty">Select teeth on the chart then click a procedure to begin</div>
                }
            </div>

            @* Summary *@
            @if (currentItems.Count > 0)
            {
                <div class="tp-summary">
                    <div class="tp-summary-row">
                        <span>Actual Price</span>
                        <strong>PKR @currentItems.Sum(i => i.BasePrice).ToString("N0")</strong>
                    </div>
                    <div class="tp-summary-row">
                        <span>Total Discount</span>
                        <strong class="tp-discount-text">PKR @currentItems.Sum(i => i.DiscountAmount).ToString("N0")</strong>
                    </div>
                    <div class="tp-summary-row tp-summary-final">
                        <span>After Discount Price</span>
                        <strong class="tp-final-text">PKR @currentItems.Sum(i => i.FinalPrice).ToString("N0")</strong>
                    </div>
                </div>
            }

            @* History *@
            @if (history.Count > 0)
            {
                <div class="tp-history">
                    <div class="tp-history-title">Treatment History — @patientName</div>
                    @foreach (var plan in history.OrderByDescending(p => p.CreatedAt))
                    {
                        <div class="tp-history-plan">
                            <div class="tp-history-header">
                                <span>@plan.CreatedAt.ToString("dd MMM yyyy")</span>
                                <button class="tp-del-btn" @onclick="() => DeletePlan(plan.Id)">Delete</button>
                            </div>
                            <table class="tp-table tp-table-sm">
                                <thead>
                                    <tr>
                                        <th>Teeth</th>
                                        <th>Procedure</th>
                                        <th>Price/Unit</th>
                                        <th>Qty</th>
                                        <th>Total</th>
                                        <th>Discount</th>
                                        <th>Final</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in plan.Items)
                                    {
                                        <tr>
                                            <td>@item.ToothNumbers</td>
                                            <td>@item.Procedure @(item.Procedure != item.ProcedureVariant ? item.ProcedureVariant : "")</td>
                                            <td>@item.PricePerUnit.ToString("N0")</td>
                                            <td>@item.NumberOfTeeth</td>
                                            <td>@item.BasePrice.ToString("N0")</td>
                                            <td>@item.DiscountAmount.ToString("N0")</td>
                                            <td class="tp-final-price">@item.FinalPrice.ToString("N0")</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr class="tp-totals-row">
                                        <td colspan="4">TOTAL</td>
                                        <td>@plan.Items.Sum(i => i.BasePrice).ToString("N0")</td>
                                        <td>@plan.Items.Sum(i => i.DiscountAmount).ToString("N0")</td>
                                        <td class="tp-final-price">@plan.Items.Sum(i => i.FinalPrice).ToString("N0")</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<style>
    .tp-wrapper { font-family: 'Segoe UI', sans-serif; background: #f0f2f5; min-height: 100vh; padding: 10px; }

    .tp-topbar { display: flex; justify-content: space-between; align-items: center; background: #1a1a2e; padding: 10px 16px; border-radius: 8px; margin-bottom: 10px; }
    .tp-topbar-left { display: flex; align-items: center; gap: 12px; }
    .tp-patient-input { width: 320px; padding: 8px 12px; border-radius: 6px; border: none; font-size: 14px; }
    .tp-patient-badge { background: #28a745; color: white; padding: 5px 12px; border-radius: 20px; font-weight: bold; font-size: 13px; }
    .tp-save-msg { color: #90ee90; font-weight: bold; }
    .tp-error-msg { color: #ffcc00; font-weight: bold; }

    .tp-chart-area { background: white; border-radius: 8px; padding: 10px 6px 6px; margin-bottom: 10px; box-shadow: 0 1px 4px rgba(0,0,0,0.1); }
    .tp-chart-label-row { display: flex; justify-content: space-around; margin-bottom: 4px; }
    .tp-chart-label { font-size: 11px; color: #888; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; }
    .tp-teeth-row { display: flex; justify-content: center; align-items: flex-end; gap: 2px; }
    .tp-lower-row { align-items: flex-start; margin-top: 2px; }
    .tp-midline { width: 2px; background: #ccc; height: 80px; margin: 0 6px; border-radius: 2px; }

    .tp-tooth { display: flex; flex-direction: column; align-items: center; cursor: pointer; padding: 2px; border-radius: 6px; border: 2px solid transparent; transition: all 0.15s; color: #c8b89a; width: 44px; user-select: none; }
    .tp-tooth:hover { border-color: #28a745; color: #28a745; background: #f0fff4; }
    .tp-tooth-selected { color: #28a745 !important; border-color: #28a745 !important; background: #d4edda !important; }
    .tp-tooth-svg { width: 36px; height: 56px; }
    .tp-tooth-svg-flipped { transform: scaleY(-1); }
    .tp-tooth-num { font-size: 11px; font-weight: 700; color: #555; }
    .tp-tooth-selected .tp-tooth-num { color: #155724; }

    .tp-selected-bar { display: flex; justify-content: center; align-items: center; gap: 12px; margin-top: 6px; padding: 6px; background: #e8f5e9; border-radius: 6px; font-size: 13px; }
    .tp-clear-btn { background: #dc3545; color: white; border: none; border-radius: 4px; padding: 3px 10px; cursor: pointer; font-size: 12px; }

    .tp-body { display: flex; gap: 10px; }

    .tp-panels { width: 420px; flex-shrink: 0; display: flex; flex-direction: column; gap: 8px; }
    .tp-panel-row { display: flex; gap: 8px; }
    .tp-panel { flex: 1; border-radius: 8px; padding: 10px; display: flex; flex-direction: column; gap: 6px; }
    .tp-panel-title { font-weight: 800; font-size: 13px; text-align: center; letter-spacing: 1px; margin-bottom: 4px; }
    .tp-panel-field { display: flex; flex-direction: column; gap: 2px; }
    .tp-panel-field label { font-size: 11px; font-weight: 600; }
    .tp-input { border: none; border-radius: 4px; padding: 4px 8px; font-size: 12px; background: rgba(255,255,255,0.7); width: 100%; }
    .tp-select { border: none; border-radius: 4px; padding: 4px 8px; font-size: 12px; background: rgba(255,255,255,0.7); width: 100%; cursor: pointer; }
    .tp-add-btn { margin-top: 4px; background: rgba(0,0,0,0.2); color: white; border: 1px solid rgba(255,255,255,0.3); border-radius: 4px; padding: 5px; font-size: 12px; font-weight: 700; cursor: pointer; transition: background 0.15s; }
    .tp-add-btn:hover { background: rgba(0,0,0,0.35); }
    .tp-add-btn-alt { background: rgba(0,0,0,0.1); }
    .tp-panel-crown-btns { display: flex; gap: 6px; }
    .tp-panel-crown-btns .tp-add-btn { flex: 1; }

    .tp-panel-extraction { background: linear-gradient(135deg, #c8860a, #e6a020); color: white; }
    .tp-panel-filling    { background: linear-gradient(135deg, #1565c0, #1e88e5); color: white; }
    .tp-panel-rct        { background: linear-gradient(135deg, #00796b, #26a69a); color: white; }
    .tp-panel-crown      { background: linear-gradient(135deg, #00838f, #26c6da); color: white; }
    .tp-panel-implant    { background: linear-gradient(135deg, #4a148c, #7b1fa2); color: white; }

    .tp-panel-extra { flex: 1; display: flex; flex-direction: column; gap: 5px; background: transparent; padding: 0; }
    .tp-extra-btn { border: none; border-radius: 6px; padding: 9px 8px; font-size: 12px; font-weight: 700; color: white; cursor: pointer; text-align: center; transition: opacity 0.15s; }
    .tp-extra-btn:hover { opacity: 0.85; }
    .tp-extra-reendo  { background: linear-gradient(90deg, #e53935, #ff7043); }
    .tp-extra-braces  { background: linear-gradient(90deg, #c62828, #e53935); }
    .tp-extra-scaling { background: linear-gradient(90deg, #e64a19, #ff8a65); }
    .tp-extra-sinus   { background: linear-gradient(90deg, #bf360c, #ff7043); }
    .tp-extra-bone    { background: linear-gradient(90deg, #b71c1c, #e53935); }
    .tp-extra-veneer  { background: linear-gradient(90deg, #6a1b9a, #ab47bc); }
    .tp-extra-denture { background: linear-gradient(90deg, #37474f, #607d8b); }

    .tp-action-row { display: flex; gap: 8px; margin-top: 4px; }
    .tp-action-btn { flex: 1; padding: 10px; border: none; border-radius: 6px; font-size: 13px; font-weight: 700; cursor: pointer; transition: opacity 0.15s; }
    .tp-action-btn:hover { opacity: 0.85; }
    .tp-btn-save  { background: #fdd835; color: #333; }
    .tp-btn-print { background: #26a69a; color: white; }
    .tp-btn-clear { background: #e53935; color: white; }

    .tp-table-area { flex: 1; display: flex; flex-direction: column; gap: 10px; min-width: 0; }
    .tp-table-wrapper { background: white; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.1); }
    .tp-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .tp-table thead tr { background: #1565c0; color: white; }
    .tp-table th { padding: 9px 10px; text-align: left; font-weight: 600; font-size: 12px; }
    .tp-table td { padding: 7px 10px; border-bottom: 1px solid #eee; }
    .tp-row-even { background: #fffde7; }
    .tp-row-odd  { background: white; }
    .tp-final-price { font-weight: 700; color: #1565c0; }
    .tp-discount-input { width: 80px; border: 1px solid #ccc; border-radius: 4px; padding: 3px 6px; font-size: 12px; }
    .tp-del-btn { background: #e53935; color: white; border: none; border-radius: 4px; padding: 3px 8px; cursor: pointer; font-size: 12px; }
