@page "/treatmentplanning"
@using Odous.Models
@using Odous.Services
@inject PatientService PatientService
@inject TreatmentPlanService TreatmentPlanService
@inject IJSRuntime JS

<div class="container-fluid mt-4">
    <div class="card">
        <div class="card-header bg-success text-white">
            <h3>🦷 Treatment Planning</h3>
        </div>
        <div class="card-body">

            @* Patient Search *@
            <div class="row mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Patient Name *</label>
                    <input class="form-control form-control-lg"
                           list="patientList"
                           @bind="patientName"
                           @bind:event="oninput"
                           placeholder="Type or select patient..." />
                    <datalist id="patientList">
                        @foreach (var p in patients)
                        {
                            <option value="@p.Name">@p.Name</option>
                        }
                    </datalist>
                </div>
                @if (!string.IsNullOrEmpty(patientName))
                {
                    <div class="col-md-6 d-flex align-items-end">
                        <span class="badge bg-success fs-6 p-2">Active Patient: @patientName</span>
                    </div>
                }
            </div>

            @* Dental Chart with Tooth Shapes *@
            <div class="card mb-4 border-secondary">
                <div class="card-header bg-light fw-bold">Dental Chart — Click on any tooth to select</div>
                <div class="card-body">
                    <div class="dental-chart">
                        <!-- Upper Teeth -->
                        <div class="teeth-row upper-teeth">
                            <div class="tooth-container" style="text-align: center;">
                                <div class="quadrant-label">Upper Right</div>
                                <div class="teeth-group">
                                    @for (int i = upperRight.Length - 1; i >= 0; i--)
                                    {
                                        var tooth = upperRight[i];
                                        <div class="tooth-wrapper @(selectedTeeth.Contains(tooth) ? "selected" : "")" @onclick="() => ToggleTooth(tooth)">
                                            <svg viewBox="0 0 60 80" class="tooth-svg">
                                                <path d="M30 10 C20 10, 10 20, 10 35 C10 50, 15 65, 20 75 C22 78, 25 80, 30 80 C35 80, 38 78, 40 75 C45 65, 50 50, 50 35 C50 20, 40 10, 30 10 Z"
                                                      fill="@(selectedTeeth.Contains(tooth) ? "#4CAF50" : "#FFFFFF")"
                                                      stroke="#333"
                                                      stroke-width="2.5" />
                                                <text x="30" y="48" text-anchor="middle" font-size="14" font-weight="bold" fill="@(selectedTeeth.Contains(tooth) ? "white" : "#333")">@tooth</text>
                                            </svg>
                                        </div>
                                    }
                                </div>
                            </div>
                            <div class="tooth-container" style="text-align: center;">
                                <div class="quadrant-label">Upper Left</div>
                                <div class="teeth-group">
                                    @foreach (var tooth in upperLeft)
                                    {
                                        <div class="tooth-wrapper @(selectedTeeth.Contains(tooth) ? "selected" : "")" @onclick="() => ToggleTooth(tooth)">
                                            <svg viewBox="0 0 60 80" class="tooth-svg">
                                                <path d="M30 10 C20 10, 10 20, 10 35 C10 50, 15 65, 20 75 C22 78, 25 80, 30 80 C35 80, 38 78, 40 75 C45 65, 50 50, 50 35 C50 20, 40 10, 30 10 Z"
                                                      fill="@(selectedTeeth.Contains(tooth) ? "#4CAF50" : "#FFFFFF")"
                                                      stroke="#333"
                                                      stroke-width="2.5" />
                                                <text x="30" y="48" text-anchor="middle" font-size="14" font-weight="bold" fill="@(selectedTeeth.Contains(tooth) ? "white" : "#333")">@tooth</text>
                                            </svg>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Lower Teeth -->
                        <div class="teeth-row lower-teeth mt-4">
                            <div class="tooth-container" style="text-align: center;">
                                <div class="quadrant-label">Lower Right</div>
                                <div class="teeth-group">
                                    @for (int i = lowerRight.Length - 1; i >= 0; i--)
                                    {
                                        var tooth = lowerRight[i];
                                        <div class="tooth-wrapper @(selectedTeeth.Contains(tooth) ? "selected" : "")" @onclick="() => ToggleTooth(tooth)">
                                            <svg viewBox="0 0 60 80" class="tooth-svg">
                                                <path d="M30 80 C20 80, 10 70, 10 55 C10 40, 15 25, 20 15 C22 12, 25 10, 30 10 C35 10, 38 12, 40 15 C45 25, 50 40, 50 55 C50 70, 40 80, 30 80 Z"
                                                      fill="@(selectedTeeth.Contains(tooth) ? "#4CAF50" : "#FFFFFF")"
                                                      stroke="#333"
                                                      stroke-width="2.5" />
                                                <text x="30" y="45" text-anchor="middle" font-size="14" font-weight="bold" fill="@(selectedTeeth.Contains(tooth) ? "white" : "#333")">@tooth</text>
                                            </svg>
                                        </div>
                                    }
                                </div>
                            </div>
                            <div class="tooth-container" style="text-align: center;">
                                <div class="quadrant-label">Lower Left</div>
                                <div class="teeth-group">
                                    @foreach (var tooth in lowerLeft)
                                    {
                                        <div class="tooth-wrapper @(selectedTeeth.Contains(tooth) ? "selected" : "")" @onclick="() => ToggleTooth(tooth)">
                                            <svg viewBox="0 0 60 80" class="tooth-svg">
                                                <path d="M30 80 C20 80, 10 70, 10 55 C10 40, 15 25, 20 15 C22 12, 25 10, 30 10 C35 10, 38 12, 40 15 C45 25, 50 40, 50 55 C50 70, 40 80, 30 80 Z"
                                                      fill="@(selectedTeeth.Contains(tooth) ? "#4CAF50" : "#FFFFFF")"
                                                      stroke="#333"
                                                      stroke-width="2.5" />
                                                <text x="30" y="45" text-anchor="middle" font-size="14" font-weight="bold" fill="@(selectedTeeth.Contains(tooth) ? "white" : "#333")">@tooth</text>
                                            </svg>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (selectedTeeth.Count > 0)
                    {
                        <div class="mt-3 text-center">
                            <span class="badge bg-primary fs-6">Selected Teeth: @string.Join(", ", selectedTeeth.OrderBy(t => t))</span>
                            <button class="btn btn-sm btn-outline-secondary ms-2" @onclick="ClearTeeth">Clear Selection</button>
                        </div>
                    }
                </div>
            </div>

            @* Procedure Buttons *@
            <div class="card mb-4 border-secondary">
                <div class="card-header bg-light fw-bold">Procedures</div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(procedureError))
                    {
                        <div class="alert alert-warning alert-dismissible fade show" role="alert">
                            @procedureError
                            <button type="button" class="btn-close" @onclick="() => procedureError = null"></button>
                        </div>
                    }

                    <div class="row g-2">
                        <div class="col-auto">
                            <button class="btn btn-danger" @onclick='() => AddProcedure("Extraction", "Simple Extraction", 2500)'>
                                🦷 Extraction (2,500)
                            </button>
                        </div>

                        <div class="col-auto">
                            <div class="dropdown">
                                <button class="btn btn-primary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                    🪥 Filling
                                </button>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" href="#" @onclick='() => AddProcedure("Filling", "Composite (White)", 2500)'>Composite — PKR 2,500</a></li>
                                    <li><a class="dropdown-item" href="#" @onclick='() => AddProcedure("Filling", "Glass Ionomer", 3500)'>Glass Ionomer — PKR 3,500</a></li>
                                    <li><a class="dropdown-item" href="#" @onclick='() => AddProcedure("Filling", "Amalgam (Silver)", 2000)'>Amalgam — PKR 2,000</a></li>
                                </ul>
                            </div>
                        </div>

                        <div class="col-auto">
                            <button class="btn btn-warning" @onclick='() => AddProcedure("RCT", "Root Canal Treatment", 7500)'>
                                🔧 RCT (7,500)
                            </button>
                        </div>

                        <div class="col-auto">
                            <div class="dropdown">
                                <button class="btn btn-success dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                    👑 Crown
                                </button>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" href="#" @onclick='() => AddProcedure("Crown", "PFM (Metal-Ceramic)", 8000)'>PFM — PKR 8,000</a></li>
                                    <li><a class="dropdown-item" href="#" @onclick='() => AddProcedure("Crown", "Zirconia", 21000)'>Zirconia — PKR 21,000</a></li>
                                    <li><a class="dropdown-item" href="#" @onclick='() => AddProcedure("Crown", "Full Ceramic (e.max)", 25000)'>Full Ceramic — PKR 25,000</a></li>
                                </ul>
                            </div>
                        </div>

                        <div class="col-auto">
                            <button class="btn btn-info" @onclick='() => AddProcedure("Implant", "Dental Implant", 75000)'>
                                🔩 Implant (75,000)
                            </button>
                        </div>

                        <div class="col-auto">
                            <button class="btn btn-secondary" @onclick='() => AddProcedure("Scaling", "Scaling & Polishing", 6500)'>
                                ✨ Scaling (6,500)
                            </button>
                        </div>

                        <div class="col-auto">
                            <button class="btn btn-dark" @onclick='() => AddProcedure("Veneer", "Porcelain Veneer", 28000)'>
                                💎 Veneer (28,000)
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            @* Current Treatment Plan Items *@
            @if (currentItems.Count > 0)
            {
                <div class="card mb-4 border-primary" id="printArea">
                    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                        <span class="fw-bold">Treatment Plan for @patientName</span>
                        <div>
                            <button class="btn btn-sm btn-light me-2" @onclick="PrintPlan">🖨️ Print</button>
                            <button class="btn btn-sm btn-success" @onclick="SavePlan">💾 Save Plan</button>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-bordered mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Tooth/Teeth</th>
                                    <th>Procedure</th>
                                    <th>Variant</th>
                                    <th>Base Price</th>
                                    <th>Discount</th>
                                    <th>Final Price</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < currentItems.Count; i++)
                                {
                                    var item = currentItems[i];
                                    var index = i;
                                    <tr>
                                        <td>@(i + 1)</td>
                                        <td><strong>@item.ToothNumbers</strong></td>
                                        <td>@item.Procedure</td>
                                        <td>@item.ProcedureVariant</td>
                                        <td>PKR @item.BasePrice.ToString("N0")</td>
                                        <td>
                                            <input type="number"
                                                   class="form-control form-control-sm"
                                                   style="width: 100px"
                                                   @bind="item.Discount"
                                                   @bind:event="onchange"
                                                   step="100" />
                                        </td>
                                        <td class="fw-bold text-success">PKR @item.FinalPrice.ToString("N0")</td>
                                        <td>
                                            <button class="btn btn-sm btn-danger" @onclick="() => RemoveItem(index)">Remove</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-secondary">
                                <tr>
                                    <td colspan="4" class="text-end fw-bold">TOTAL:</td>
                                    <td class="fw-bold">PKR @currentItems.Sum(i => i.BasePrice).ToString("N0")</td>
                                    <td class="fw-bold text-danger">PKR @currentItems.Sum(i => i.Discount).ToString("N0")</td>
                                    <td class="fw-bold text-success">PKR @currentItems.Sum(i => i.FinalPrice).ToString("N0")</td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                    <div class="card-footer">
                        <button class="btn btn-outline-danger" @onclick="ClearPlan">🗑️ Clear All Items</button>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(saveMessage))
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @saveMessage
                        <button type="button" class="btn-close" @onclick="() => saveMessage = null"></button>
                    </div>
                }
            }

            @* Treatment History *@
            @if (history.Count > 0)
            {
                <div class="card border-secondary">
                    <div class="card-header bg-light fw-bold">
                        📜 Treatment History - @patientName
                    </div>
                    <div class="card-body">
                        @foreach (var plan in history)
                        {
                            <div class="border rounded p-3 mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <div>
                                        <strong>Date:</strong> @plan.CreatedAt.ToString("dd MMM yyyy, hh:mm tt") |
                                        <strong>Total:</strong> <span class="text-success">PKR @plan.Items.Sum(i => i.FinalPrice).ToString("N0")</span>
                                    </div>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeletePlan(plan.Id)">
                                        Delete Plan
                                    </button>
                                </div>
                                <table class="table table-sm table-bordered">
                                    <thead>
                                        <tr>
                                            <th>Tooth/Teeth</th>
                                            <th>Procedure</th>
                                            <th>Variant</th>
                                            <th>Base Price</th>
                                            <th>Discount</th>
                                            <th>Final Price</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in plan.Items)
                                        {
                                            <tr>
                                                <td>@item.ToothNumbers</td>
                                                <td>@item.Procedure</td>
                                                <td>@item.ProcedureVariant</td>
                                                <td>PKR @item.BasePrice.ToString("N0")</td>
                                                <td>PKR @item.Discount.ToString("N0")</td>
                                                <td class="fw-bold text-success">PKR @item.FinalPrice.ToString("N0")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .dental-chart {
        background: #f8f9fa;
        padding: 20px;
        border-radius: 10px;
    }
    
    .teeth-row {
        display: flex;
        justify-content: center;
        gap: 40px;
        flex-wrap: wrap;
    }
    
    .tooth-container {
        flex: 1;
        min-width: 300px;
    }
    
    .teeth-group {
        display: flex;
        justify-content: center;
        gap: 2px;
        flex-wrap: wrap;
    }
    
    .tooth-wrapper {
        cursor: pointer;
        transition: transform 0.2s;
        width: 45px;
        margin: 2px;
    }
    
        .tooth-wrapper:hover {
            transform: scale(1.1);
        }
    
        .tooth-wrapper.selected .tooth-svg path {
            fill: #4CAF50;
            stroke: #2E7D32;
            filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2));
        }
    
    .tooth-svg {
        width: 100%;
        height: auto;
        display: block;
    }
    
    .quadrant-label {
        font-weight: bold;
        margin-bottom: 10px;
        color: #555;
        font-size: 14px;
    }
    
    .upper-teeth {
        margin-bottom: 20px;
    }
    
    @@media print {
        body * {
            visibility: hidden;
        }

        #printArea, #printArea * {
            visibility: visible;
        }

        #printArea {
            position: absolute;
            left: 0;
            top: 0;
            width: 100%;
            margin: 0;
            padding: 20px;
        }

        .btn, .btn-close, .dropdown-toggle {
            display: none !important;
        }

        .tooth-wrapper {
            break-inside: avoid;
        }
    }
</style>

@code {
    private List<Patient> patients = new();
    private string patientName = "";
    private List<int> selectedTeeth = new();
    private List<TreatmentPlanItem> currentItems = new();
    private List<TreatmentPlan> history = new();
    private string? procedureError;
    private string? saveMessage;

    // Universal Tooth Numbering System (1-32)
    private int[] upperRight = { 1, 2, 3, 4, 5, 6, 7, 8 };
    private int[] upperLeft = { 9, 10, 11, 12, 13, 14, 15, 16 };
    private int[] lowerRight = { 32, 31, 30, 29, 28, 27, 26, 25 };
    private int[] lowerLeft = { 17, 18, 19, 20, 21, 22, 23, 24 };

    protected override async Task OnInitializedAsync()
    {
        await LoadPatients();
    }

    private async Task LoadPatients()
    {
        patients = await PatientService.GetAllPatientsAsync();
    }

    private async Task OnPatientSelected(ChangeEventArgs e)
    {
        patientName = e.Value?.ToString() ?? "";
        await LoadPatientHistory();
    }

    private async Task LoadPatientHistory()
    {
        saveMessage = null;
        if (!string.IsNullOrWhiteSpace(patientName))
        {
            history = await TreatmentPlanService.GetByPatientAsync(patientName);
        }
        else
        {
            history = new List<TreatmentPlan>();
        }
    }

    private void ToggleTooth(int tooth)
    {
        if (selectedTeeth.Contains(tooth))
            selectedTeeth.Remove(tooth);
        else
            selectedTeeth.Add(tooth);
        
        procedureError = null;
        StateHasChanged();
    }

    private void ClearTeeth()
    {
        selectedTeeth.Clear();
        StateHasChanged();
    }

    private void AddProcedure(string procedure, string variant, decimal basePrice)
    {
        // Validation
        if (string.IsNullOrWhiteSpace(patientName))
        {
            procedureError = "❌ Please select a patient first!";
            return;
        }

        if (selectedTeeth.Count == 0)
        {
            procedureError = "❌ Please select at least one tooth first!";
            return;
        }

        // Add procedure for each selected tooth
        foreach (var tooth in selectedTeeth.OrderBy(t => t))
        {
            currentItems.Add(new TreatmentPlanItem
            {
                ToothNumbers = tooth.ToString(),
                Procedure = procedure,
                ProcedureVariant = variant,
                BasePrice = basePrice,
                Discount = 0
            });
        }

        // Clear selection after adding
        selectedTeeth.Clear();
        procedureError = null;
        StateHasChanged();
    }

    private void RemoveItem(int index)
    {
        if (index >= 0 && index < currentItems.Count)
        {
            currentItems.RemoveAt(index);
            StateHasChanged();
        }
    }

    private void ClearPlan()
    {
        currentItems.Clear();
        saveMessage = null;
        StateHasChanged();
    }

    private async Task SavePlan()
    {
        if (string.IsNullOrWhiteSpace(patientName))
        {
            procedureError = "❌ Please select a patient first!";
            return;
        }

        if (currentItems.Count == 0)
        {
            procedureError = "❌ No treatment items to save!";
            return;
        }

        try
        {
            var plan = new TreatmentPlan
            {
                PatientName = patientName,
                CreatedAt = DateTime.UtcNow,
                Items = currentItems.Select(i => new TreatmentPlanItem
                {
                    ToothNumbers = i.ToothNumbers,
                    Procedure = i.Procedure,
                    ProcedureVariant = i.ProcedureVariant,
                    BasePrice = i.BasePrice,
                    Discount = i.Discount
                }).ToList()
            };

            await TreatmentPlanService.SavePlanAsync(plan);
            saveMessage = $"✅ Treatment plan saved successfully! Total: PKR {currentItems.Sum(i => i.FinalPrice).ToString("N0")}";
            
            // Clear current items and refresh history
            currentItems.Clear();
            await LoadPatientHistory();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            procedureError = $"❌ Error saving plan: {ex.Message}";
        }
    }

    private async Task DeletePlan(int id)
    {
        if (await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this treatment plan?"))
        {
            await TreatmentPlanService.DeletePlanAsync(id);
            await LoadPatientHistory();
            StateHasChanged();
        }
    }

    private async Task PrintPlan()
    {
        await JS.InvokeVoidAsync("print");
    }
}