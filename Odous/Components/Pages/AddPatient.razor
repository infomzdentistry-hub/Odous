@page "/addpatient"
@using Odous.Models
@using Odous.Services
@inject PatientService PatientService
@inject NavigationManager Navigation

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Add New Patient</h4>
                </div>
                <div class="card-body">
                    <EditForm FormName="addPatientForm" Model="@newPatient" OnValidSubmit="HandleSave">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Full Name</label>
                            <InputText @bind-Value="newPatient.Name" class="form-control" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Age</label>
                                <InputNumber @bind-Value="newPatient.Age" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Phone</label>
                                <InputText @bind-Value="newPatient.Phone" class="form-control" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Email</label>
                                <InputText @bind-Value="newPatient.Email" type="email" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Last Visit</label>
                                <InputDate @bind-Value="newPatient.LastVisit" class="form-control" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Notes</label>
                            <InputTextArea @bind-Value="newPatient.Notes" class="form-control" rows="3" />
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary" disabled="@isSaving">@(isSaving ? "Saving..." : "Save Patient")</button>
                            <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancel</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private Patient newPatient = new Patient();
    private bool isSaving = false;

    private async Task HandleSave()
    {
        if (string.IsNullOrWhiteSpace(newPatient.Name))
        {
            return;
        }

        isSaving = true;
        await PatientService.AddPatientAsync(newPatient);
        isSaving = false;
        
        Navigation.NavigateTo("/patients", forceLoad: true);
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/patients");
    }
}