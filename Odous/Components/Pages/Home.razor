@page "/"
@using Odous.Services
@inject AuthService AuthService

<div class="container mt-4">
    <div class="jumbotron bg-light p-5 rounded">
        <h1 class="display-4">🏥 Welcome to Odous Dental Clinic</h1>
        <p class="lead">Complete dental clinic management system</p>
        <hr class="my-4">
        
        @if (AuthService.IsLoggedIn)
        {
            var currentUser = AuthService.GetCurrentUser();
            <p>Welcome back, <strong>@currentUser?.Name</strong>!</p>
            <p>Select an option from the menu to get started.</p>
        }
        else
        {
            <p>Please login to access the system.</p>
            <a class="btn btn-primary btn-lg" href="/login" role="button">Login</a>
        }
    </div>
    
    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">Patient Management</h5>
                    <p class="card-text">Add, edit, and manage patient records</p>
                    <a href="/patients" class="btn btn-primary">View Patients</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">Appointments</h5>
                    <p class="card-text">Schedule and manage appointments</p>
                    <a href="/appointments" class="btn btn-primary">View Appointments</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">Treatment Planning</h5>
                    <p class="card-text">Create and manage treatment plans</p>
                    <a href="/treatmentplanning" class="btn btn-primary">Treatment Plans</a>
                </div>
            </div>
        </div>
    </div>
</div>
