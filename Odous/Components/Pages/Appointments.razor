@page "/appointments"
@using Odous.Models
@using Odous.Services
@inject AppointmentService AppointmentService

<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-success text-white">
            <h3>Appointments</h3>
        </div>
        <div class="card-body">
            <a href="/addappointment" class="btn btn-primary mb-3">New Appointment</a>

            <div class="alert alert-info">
                <strong>Total:</strong> @allAppointments.Count
            </div>

            @if (allAppointments.Count == 0)
            {
                <p>No appointments yet.</p>
            }
            else
            {
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Patient</th>
                            <th>Contact</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Service</th>
                            <th>Dentist</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var appointment in allAppointments)
                        {
                            <tr>
                                <td>@appointment.AppointmentMR</td>
                                <td>@appointment.PatientName</td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(appointment.ContactNo))
                                    {
                                        var cleanNumber = appointment.ContactNo.Replace("+", "").Replace(" ", "").Replace("-", "");
                                        var waUrl = $"https://wa.me/{cleanNumber}";
                                        <a href="@waUrl" target="_blank" class="btn btn-sm btn-outline-success">
                                            @appointment.ContactNo
                                        </a>
                                    }
                                </td>
                                <td>@appointment.AppointmentDate.ToString("dd MMM yyyy")</td>
                                <td>@appointment.StartTime.ToString("HH:mm") - @appointment.EndTime.ToString("HH:mm")</td>
                                <td>@appointment.ServiceType</td>
                                <td>@appointment.Dentist</td>
                                <td>
                                    @if (appointment.Status == "Scheduled")
                                    {
                                        <span class="badge bg-warning">Scheduled</span>
                                    }
                                    else if (appointment.Status == "Confirmed")
                                    {
                                        <span class="badge bg-primary">Confirmed</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">@appointment.Status</span>
                                    }
                                </td>
                                <td>
                                    <button class="btn btn-danger btn-sm" @onclick="() => DeleteAppointment(appointment.Id)">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

@code {
    private List<Appointment> allAppointments = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAppointments();
    }

    private async Task LoadAppointments()
    {
        allAppointments = await AppointmentService.GetAllAppointmentsAsync();
        StateHasChanged();
    }

    private async Task DeleteAppointment(int id)
    {
        await AppointmentService.DeleteAppointmentAsync(id);
        await LoadAppointments();
    }
}