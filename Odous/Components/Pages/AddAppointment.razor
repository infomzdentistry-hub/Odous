@page "/addappointment"
@using Odous.Models
@using Odous.Services
@inject AppointmentService AppointmentService
@inject PatientService PatientService
@inject NavigationManager Navigation

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-gradient-success text-white rounded-top-4 py-3">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-calendar-plus-fill fs-1 me-3"></i>
                        <div>
                            <h3 class="mb-0 fw-bold">Schedule Appointment</h3>
                            <p class="mb-0 opacity-75">Book a new dental appointment</p>
                        </div>
                    </div>
                </div>
                <div class="card-body p-4">
                    <EditForm Model="@newAppointment" OnValidSubmit="HandleSave">

                        <!-- Patient Name with Dropdown -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Patient Name <span class="text-danger">*</span>
                            </label>
                            <input @bind="newAppointment.PatientName"
                                   class="form-control form-control-lg"
                                   placeholder="Select or type patient name"
                                   list="patientList"
                                   autocomplete="off" />
                            <datalist id="patientList">
                                @foreach (var patient in patients)
                                {
                                    <option value="@patient.Name">
                                        @patient.Name (ID: @patient.PatientMR)
                                    </option>
                                }
                            </datalist>
                        </div>

                        <!-- Appointment Date -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Appointment Date</label>
                            <InputDate @bind-Value="newAppointment.AppointmentDate"
                                       class="form-control" />
                        </div>

                        <!-- Start & End Time -->
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Start Time</label>
                                <input type="time"
                                       @bind="newAppointment.StartTime"
                                       class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">End Time</label>
                                <input type="time"
                                       @bind="newAppointment.EndTime"
                                       class="form-control" />
                            </div>
                        </div>

                        <!-- Service Type & Dentist -->
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Service Type</label>
                                <input @bind="newAppointment.ServiceType"
                                       class="form-control"
                                       placeholder="e.g., Checkup, Cleaning" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Dentist</label>
                                <input @bind="newAppointment.Dentist"
                                       class="form-control"
                                       placeholder="e.g., Dr. Sarah Ahmed" />
                            </div>
                        </div>

                        <!-- Reason for Visit -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Reason for Visit</label>
                            <textarea @bind="newAppointment.Reason"
                                      class="form-control"
                                      rows="2"></textarea>
                        </div>

                        <!-- Procedure Notes -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Procedure Notes</label>
                            <textarea @bind="newAppointment.ProcedureNotes"
                                      class="form-control"
                                      rows="3"></textarea>
                        </div>

                        <!-- Status -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Status</label>
                            <select @bind="newAppointment.Status" class="form-select">
                                <option value="Scheduled">Scheduled</option>
                                <option value="Confirmed">Confirmed</option>
                                <option value="In Progress">In Progress</option>
                                <option value="Completed">Completed</option>
                                <option value="Cancelled">Cancelled</option>
                            </select>
                        </div>

                        <hr />

                        <div class="d-flex gap-3 justify-content-end">
                            <button type="button"
                                    class="btn btn-outline-secondary px-4"
                                    @onclick="Cancel">
                                Cancel
                            </button>
                            <button type="submit" class="btn btn-success px-5">
                                Schedule Appointment
                            </button>
                        </div>

                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-gradient-success {
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
    }
</style>

@code {
    private Appointment newAppointment = new Appointment();
    private List<Patient> patients = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadPatients();
    }

    private async Task LoadPatients()
    {
        patients = await PatientService.GetAllPatientsAsync();
        StateHasChanged();
    }

    private async Task HandleSave()
    {
        if (string.IsNullOrWhiteSpace(newAppointment.PatientName))
            return;

        await AppointmentService.AddAppointmentAsync(newAppointment);
        Navigation.NavigateTo("/appointments", forceLoad: true);
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/appointments");
    }
}