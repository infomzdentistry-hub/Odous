@page "/addappointment"
@using Odous.Models
@using Odous.Services
@inject AppointmentService AppointmentService
@inject PatientService PatientService
@inject NavigationManager Navigation

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h3>Schedule Appointment</h3>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label>Patient Name</label>
                        <input @bind="patientName" class="form-control" list="patientList" />
                        <datalist id="patientList">
                            @foreach (var patient in patients)
                            {
                                <option value="@patient.Name">@patient.Name</option>
                            }
                        </datalist>
                    </div>

                    <div class="mb-3">
                        <label>Date</label>
                        <input type="date" class="form-control"
                               value="@appointmentDate"
                               @onchange="e => appointmentDate = e.Value?.ToString() ?? string.Empty" />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label>Start Time</label>
                            <input type="time" class="form-control"
                                   value="@startTime"
                                   @onchange="e => startTime = e.Value?.ToString() ?? string.Empty" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label>End Time</label>
                            <input type="time" class="form-control"
                                   value="@endTime"
                                   @onchange="e => endTime = e.Value?.ToString() ?? string.Empty" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label>Service Type</label>
                        <input @bind="serviceType" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label>Dentist</label>
                        <input @bind="dentist" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label>Procedure Notes</label>
                        <textarea @bind="procedureNotes" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="mb-3">
                        <label>Status</label>
                        <select @bind="status" class="form-select">
                            <option>Scheduled</option>
                            <option>Confirmed</option>
                            <option>Completed</option>
                            <option>Cancelled</option>
                        </select>
                    </div>

                    <button class="btn btn-success" @onclick="SaveAppointment">Save</button>
                    <a href="/appointments" class="btn btn-secondary">Cancel</a>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger mt-3">@errorMessage</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Patient> patients = new();
    private string patientName = "";
    private string appointmentDate = DateTime.Now.ToString("yyyy-MM-dd");
    private string startTime = "09:00";
    private string endTime = "10:00";
    private string serviceType = "";
    private string dentist = "";
    private string procedureNotes = "";
    private string status = "Scheduled";
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        patients = await PatientService.GetAllPatientsAsync();
    }

    private async Task SaveAppointment()
    {
        if (string.IsNullOrWhiteSpace(patientName))
        {
            errorMessage = "Please enter a patient name";
            return;
        }

        var newAppointment = new Appointment
        {
            PatientName = patientName,
            AppointmentDate = appointmentDate,
            StartTime = startTime,
            EndTime = endTime,
            ServiceType = serviceType,
            Dentist = dentist,
            ProcedureNotes = procedureNotes,
            Status = status
        };

        var random = new Random();
        newAppointment.AppointmentMR = random.Next(1000, 9999);

        await AppointmentService.AddAppointmentAsync(newAppointment);
        Navigation.NavigateTo("/appointments");
    }
}