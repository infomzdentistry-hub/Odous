@page "/addappointment"
@using Odous.Models
@using Odous.Services
@inject AppointmentService AppointmentService
@inject PatientService PatientService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h3>Schedule Appointment</h3>
                </div>
                <div class="card-body">

                    <div class="mb-3">
                        <label>Patient Name</label>
                        <input class="form-control" list="patientList"
                               value="@patientName"
                               @onchange="OnPatientSelected" />
                        <datalist id="patientList">
                            @foreach (var patient in patients)
                            {
                                <option value="@patient.Name">@patient.Name</option>
                            }
                        </datalist>
                    </div>

                    <div class="mb-3">
                        <label>Contact Number</label>
                        <input @bind="contactNo" class="form-control" placeholder="e.g. 923001234567" />
                        <small class="text-muted">Include country code without + (e.g. 923001234567)</small>
                    </div>

                    <div class="mb-3">
                        <label>Date</label>
                        <input type="date" class="form-control"
                               value="@AppointmentDateString"
                               @onchange="e => AppointmentDateString = e.Value?.ToString() ?? string.Empty" />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label>Start Time</label>
                            <input type="time" class="form-control"
                                   value="@StartTimeString"
                                   @onchange="e => StartTimeString = e.Value?.ToString() ?? string.Empty" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label>End Time</label>
                            <input type="time" class="form-control"
                                   value="@EndTimeString"
                                   @onchange="e => EndTimeString = e.Value?.ToString() ?? string.Empty" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label>Service Type</label>
                        <input @bind="serviceType" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label>Dentist</label>
                        <input @bind="dentist" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label>Procedure Notes</label>
                        <textarea @bind="procedureNotes" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="mb-3">
                        <label>Status</label>
                        <select @bind="status" class="form-select">
                            <option>Scheduled</option>
                            <option>Confirmed</option>
                            <option>Completed</option>
                            <option>Cancelled</option>
                        </select>
                    </div>

                    <button class="btn btn-success" @onclick="SaveAppointment">Save & Send WhatsApp</button>
                    <a href="/appointments" class="btn btn-secondary ms-2">Cancel</a>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger mt-3">@errorMessage</div>
                    }

                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Patient> patients = new();
    private string patientName = "";
    private string contactNo = "";
    private string serviceType = "";
    private string dentist = "";
    private string procedureNotes = "";
    private string status = "Scheduled";
    private string errorMessage = "";

    private string AppointmentDateString { get; set; } = DateTime.Now.ToString("yyyy-MM-dd");
    private string StartTimeString { get; set; } = "09:00";
    private string EndTimeString { get; set; } = "10:00";

    protected override async Task OnInitializedAsync()
    {
        patients = await PatientService.GetAllPatientsAsync();
    }

    private void OnPatientSelected(ChangeEventArgs e)
    {
        patientName = e.Value?.ToString() ?? string.Empty;

        // Auto-fill contact number from patient record
        var matched = patients.FirstOrDefault(p => p.Name == patientName);
        if (matched != null)
        {
            contactNo = matched.ContactNo ?? "";
        }
    }

    private async Task SaveAppointment()
    {
        try
        {
            errorMessage = "";

            if (string.IsNullOrWhiteSpace(patientName))
            {
                errorMessage = "Please enter a patient name";
                return;
            }

            if (!DateTime.TryParse(AppointmentDateString, out DateTime parsedDate))
            {
                errorMessage = "Please enter a valid date";
                return;
            }

            if (!TimeOnly.TryParse(StartTimeString, out TimeOnly parsedStart))
            {
                errorMessage = "Please enter a valid start time";
                return;
            }

            if (!TimeOnly.TryParse(EndTimeString, out TimeOnly parsedEnd))
            {
                errorMessage = "Please enter a valid end time";
                return;
            }

            var newAppointment = new Appointment
            {
                PatientName = patientName,
                ContactNo = contactNo,
                AppointmentDate = DateTime.SpecifyKind(parsedDate, DateTimeKind.Utc),
                StartTime = parsedStart,
                EndTime = parsedEnd,
                ServiceType = serviceType,
                Dentist = dentist,
                ProcedureNotes = procedureNotes,
                Status = status,
                AppointmentMR = (int)(DateTime.Now.Ticks % 100000)
            };

            await AppointmentService.AddAppointmentAsync(newAppointment);

            // Send WhatsApp message if contact number exists
            if (!string.IsNullOrWhiteSpace(contactNo))
            {
                var message = $"Hello {patientName}, your appointment at Odous Dental Clinic has been scheduled on {parsedDate:dd MMM yyyy} from {parsedStart:HH:mm} to {parsedEnd:HH:mm}. Service: {serviceType}. Please arrive 5 minutes early. Thank you!";
                var encodedMessage = Uri.EscapeDataString(message);
                var cleanNumber = contactNo.Replace("+", "").Replace(" ", "").Replace("-", "");
                var waUrl = $"https://wa.me/{cleanNumber}?text={encodedMessage}";
                await JS.InvokeVoidAsync("open", waUrl, "_blank");
            }

            Navigation.NavigateTo("/appointments");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message} | Inner: {ex.InnerException?.Message}";
        }
    }
}