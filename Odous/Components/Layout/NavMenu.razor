@* Also fix the ) expected errors in AddAppointment by removing inline ToString format calls *@

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">🏥 Odous Dental Clinic</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@navMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill"></span> Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="addpatient">
                <span class="bi bi-person-plus-fill"></span> Add Patient
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="patients">
                <span class="bi bi-person-fill"></span> Patient List
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="addappointment">
                <span class="bi bi-calendar-plus-fill"></span> Add Appointment
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="appointments">
                <span class="bi bi-calendar-fill"></span> Appointments
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="treatmentplanning">
                <span class="bi bi-clipboard2-pulse-fill"></span> Treatment Planning
            </NavLink>
        </div>

        <div class="nav-item px-3 mt-4 pt-3 border-top">
            <button class="btn btn-outline-danger btn-sm w-100" @onclick="Logout">Logout</button>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;
    private string? navMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    [Inject] private Odous.Services.AuthService? AuthService { get; set; }
    [Inject] private NavigationManager? Navigation { get; set; }

    private void Logout()
    {
        AuthService?.Logout();
        Navigation?.NavigateTo("/login", true);
    }
}